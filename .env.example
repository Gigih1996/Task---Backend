PORT=3000
NODE_ENV=development

# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Local development:
DATABASE_URL="mysql://root:password@localhost:3306/task_manager"

# Allowed frontend origins (comma-separated).
# Use "*" to allow all (dev only).
CORS_ORIGIN="http://localhost:4200"

# Railway production notes:
# - DATABASE_URL is auto-injected when you add the MySQL plugin
# - PORT is auto-injected by Railway
# - Set CORS_ORIGIN to your deployed frontend URL, e.g. https://taskflow.up.railway.app
